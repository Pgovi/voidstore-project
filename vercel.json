{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/send-order-email", "destination": "/api/send-order-email" },
    { "source": "/api/product-feed", "destination": "/api/product-feed" }
  ],
  "crons": [
    {
      "path": "/api/instagram-autopost",
      "schedule": "30 13 * * *"
    }
  ]
}
